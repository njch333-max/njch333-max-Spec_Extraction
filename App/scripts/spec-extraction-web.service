[Unit]
Description=Spec Extraction FastAPI Web Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/builder-spec-extractor
ExecStart=/opt/builder-spec-extractor/App/scripts/run_server.sh
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
