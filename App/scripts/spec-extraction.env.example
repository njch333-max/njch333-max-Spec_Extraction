SPEC_EXTRACTION_SECRET_KEY=replace-with-a-long-random-string
SPEC_EXTRACTION_ADMIN_USERNAME=admin
SPEC_EXTRACTION_ADMIN_PASSWORD=change-me
SPEC_EXTRACTION_SESSION_DOMAIN=spec.lxtransport.online
SPEC_EXTRACTION_HOST_DOMAIN=spec.lxtransport.online
SPEC_EXTRACTION_HTTPS_ONLY=1
SPEC_EXTRACTION_DATA_DIR=/var/lib/spec-extraction
SPEC_EXTRACTION_WEB_PORT=8010
SPEC_EXTRACTION_MAX_UPLOAD_MB=100
SPEC_EXTRACTION_ENABLE_OPENAI=1
SPEC_EXTRACTION_OPENAI_MODEL=gpt-4.1-mini
SPEC_EXTRACTION_ENABLE_OPENAI_VISION=1
SPEC_EXTRACTION_OPENAI_VISION_MAX_PAGES=24
SPEC_EXTRACTION_OPENAI_VISION_DPI=144
OPENAI_API_KEY=
